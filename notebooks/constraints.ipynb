   "source": [
    "from oemof import solph\n",
    "\n",
    "# Emission factor\n",
    "es = solph.EnergySystem()\n",
    "omodel = solph.Model(es)\n",
    "\n",
    "solph.constraints.emission_limit(\n",
    "    om=omodel,\n",
    "    limit=0,\n",
    ")\n"
   ]
  }
